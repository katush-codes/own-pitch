# ── Email (Resend) ───────────────────────────────────────
# Get free API key at https://resend.com
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Own. <investments@iown.app>
EMAIL_NOTIFY=investments@iown.app   # receives every submission

# ── Database (Supabase) ──────────────────────────────────
# Create free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── DD Access Codes ──────────────────────────────────────
# Comma-separated list of valid access codes
DD_ACCESS_CODES=OWN-DD-2026,NEMO-ACCESS,PRESERIESA

# ── App URL ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pitch.ownapp.co
